    <h2 class="final-title">
      <span data-lang-ru="Билеты" data-lang-en="Tickets">Билеты</span>
    </h2>
    <p class="final-sub" data-lang-ru="Места ограничены" data-lang-en="Limited spots">Места ограничены</p>
    <div class="final-buttons">
      <a href="https://web.tribute.tg/s/X01" class="ticket-btn ticket-btn--light" target="_blank" rel="noopener">
        <span data-lang-ru="Купить — RU" data-lang-en="Buy — RU">Купить — RU</span>
        <span class="ticket-btn-arrow">→</span>
      </a>
      <a href="https://web.tribute.tg/s/X02" class="ticket-btn ticket-btn--light" target="_blank" rel="noopener">
        <span data-lang-ru="Купить — EN" data-lang-en="Buy — EN">Купить — EN</span>
        <span class="ticket-btn-arrow">→</span>
      </a>
    </div>
  </div>
</section>

<!-- ═══ YOUTUBE MODAL ═══ -->
<div class="modal" id="videoModal" aria-hidden="true">
  <div class="modal-backdrop"></div>
  <div class="modal-content">
    <button class="modal-close" aria-label="Close">✕</button>
    <div class="modal-video">
      <div id="youtubePlayer"></div>
